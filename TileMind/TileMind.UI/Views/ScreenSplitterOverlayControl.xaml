<UserControl x:Class="TileMind.UI.Views.ScreenSplitterOverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TileMind.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- 底层Canvas：放置四个四边形 -->
        <Canvas x:Name="QuadCanvas" Background="Transparent">
            <local:QuadrilateralControl x:Name="QuadA" VertexChanged="OnAnyVertexChanged"
                                    TopLeft="50,50" TopRight="750,50" BottomLeft="50,550" BottomRight="750,550"/>
            <local:QuadrilateralControl x:Name="QuadB" VertexChanged="OnAnyVertexChanged"
                                    TopLeft="200,150" TopRight="600,150" BottomLeft="200,450" BottomRight="600,450"/>
            <local:QuadrilateralControl x:Name="QuadC" VertexChanged="OnAnyVertexChanged"
                                    TopLeft="25,25" TopRight="25,75" BottomLeft="100,25" BottomRight="100,75"/>
            <local:QuadrilateralControl x:Name="QuadD" VertexChanged="OnAnyVertexChanged"
                                    TopLeft="350,250" TopRight="450,250" BottomLeft="350,350" BottomRight="450,350"/>
        </Canvas>

        <!-- 上层Canvas：绘制分割线 -->
        <Canvas x:Name="LineCanvas" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
