<UserControl x:Class="TileMind.UI.View.QuadrilateralControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TileMind.UI.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Canvas x:Name="LayoutRoot">
        <!-- 半透明填充 -->
        <Path x:Name="FillPath" Fill="#40808080" Stroke="Yellow" StrokeThickness="2"/>

        <!-- 四个顶点抓手 -->
        <Thumb x:Name="TopLeftThumb" Width="12" Height="12" Cursor="SizeNWSE" Opacity="0.8"
               Canvas.Left="-6" Canvas.Top="-6" DragDelta="OnThumbDragDelta"/>
        <Thumb x:Name="TopRightThumb" Width="12" Height="12" Cursor="SizeNESW" Opacity="0.8"
               Canvas.Left="-6" Canvas.Top="-6" DragDelta="OnThumbDragDelta"/>
        <Thumb x:Name="BottomLeftThumb" Width="12" Height="12" Cursor="SizeNESW" Opacity="0.8"
               Canvas.Left="-6" Canvas.Top="-6" DragDelta="OnThumbDragDelta"/>
        <Thumb x:Name="BottomRightThumb" Width="12" Height="12" Cursor="SizeNWSE" Opacity="0.8"
               Canvas.Left="-6" Canvas.Top="-6" DragDelta="OnThumbDragDelta"/>

        <!-- 可选：边缘中点用于缩放（可省略，这里仅提供顶点调整） -->
    </Canvas>
</UserControl>
